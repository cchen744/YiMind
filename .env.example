# Copy this file to .env.local (for `vercel dev`) and fill in your key.
# On Vercel production: set these in Project → Settings → Environment Variables.

# Required: your DeepSeek API key. Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: override the upstream API host (for proxies / Azure-hosted DeepSeek)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: model id, default is deepseek-chat (V3)
# DEEPSEEK_MODEL=deepseek-chat

# Optional: CORS — restrict to your Wix domain once you've embedded.
# Example: ALLOWED_ORIGIN=https://www.claccuw.com
ALLOWED_ORIGIN=*
